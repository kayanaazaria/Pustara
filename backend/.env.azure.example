# Azure SQL runtime (Docker/Compose)
# Copy this file on the target server to a NON-repo path, e.g.:
# /opt/pustara/backend/.env.azure

# App runtime
NODE_ENV=production
NEON_CLOUD_MODE=false
PORT=3000

# Azure SQL (required in Azure mode)
DB_SERVER=your-azure-sql-server.database.windows.net
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# IMPORTANT:
# Leave DATABASE_URL empty in Azure mode to avoid Neon path activation
DATABASE_URL=

# Firebase
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_API_KEY=your_firebase_api_key

# API / AI
FASTAPI_URL=https://your-fastapi-domain
HF_TOKEN=your_hf_token_if_needed

# Redis
UPSTASH_REDIS_REST_URL=your_upstash_rest_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token
REDIS_URL=your_upstash_redis_url

# Reindex auth
CRON_SECRET=your_cron_secret
RI_SECRET=your_ri_secret

# Backup settings
BACKUP_DIR=/opt/pustara/backups
BACKUP_RETENTION_DAYS=7
ALERT_BOOKS_DROP_THRESHOLD_PERCENT=70
ALERT_BOOKS_MIN_PREVIOUS_ROWS=30

# Ops email alerts (delete + dedupe + backup fail)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=ops@your-domain.com
ALERT_EMAIL_TO=you@your-domain.com,teammate@your-domain.com
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password

# Optional
CORS_ORIGINS=https://your-frontend-domain
TURNSTILE_SECRET_KEY=your_turnstile_secret
